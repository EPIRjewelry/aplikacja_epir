# Skopiuj do .env (nie commituj) lub ustaw w profilu Windows / Cursor Automations.
# Copy-Item .env.example .env

# --- Wymagane (wszystkie tryby: auto-naprawa + bramka) ---
EPIR_BATCH_WORKER_ORIGIN=https://epir-bigquery-batch.krzysztofdzugaj.workers.dev
DATA_GUARDIAN_OPS_KEY=

# --- Cloudflare D1 read (MCP epir-data-ops, rdzeń deterministyczny lokalnie) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# --- Przełącznik LLM (domyślnie cursor + cloud) ---
# cursor | openrouter | off
EDOG_LLM_PROVIDER=cursor
# cloud | local — cloud: tylko subagent dataFlowAuditor; tsc+MCP zawsze w npm run audit (lokalnie)
EDOG_CURSOR_TARGET=cloud
CURSOR_API_KEY=

# --- Alternatywa OpenRouter (lokalnie, bez Cursor) ---
# EDOG_LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=
# EDOG_OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# --- Tylko naprawa HTTP + bramka + tsc/MCP, bez kosztu LLM ---
# EDOG_LLM_PROVIDER=off

# Opcjonalnie
# EPIR_REPO_ROOT=D:\aplikacja_epir
# EDOG_AUDITOR_MODEL_ID=claude-4-sonnet
# EPIR_ANALYST_WORKER_ORIGIN=
# ANALYST_HTTP_BEARER=
