# Skopiuj do .env (nie commituj) lub ustaw w profilu Windows / Cursor Automations.
# cp .env.example .env   # PowerShell: Copy-Item .env.example .env

# --- Cursor SDK (wymagane) ---
# Utwórz w: https://cursor.com/dashboard → Integrations → User API keys
# Format zwykle: cursor_...
CURSOR_API_KEY=

# --- Cloudflare D1 read (MCP epir-data-ops) ---
# Konto z `wrangler whoami` (Account ID):
CLOUDFLARE_ACCOUNT_ID=73283c24dc79f92edef30dcdbc98f230
# Token API: Dashboard → My Profile → API Tokens → Create → D1 Read (bez Write)
CLOUDFLARE_API_TOKEN=

# --- Worker batch (EDOG flow-health) — origin zweryfikowany w repo ---
EPIR_BATCH_WORKER_ORIGIN=https://epir-bigquery-batch.krzysztofdzugaj.workers.dev

# Ten sam Bearer co secret DATA_GUARDIAN_OPS_KEY na workerze epir-bigquery-batch.
# Wrangler NIE pokazuje wartości sekretów — musisz znać swój klucz lub ustawić nowy (patrz README).
DATA_GUARDIAN_OPS_KEY=

# Opcjonalnie
# EPIR_REPO_ROOT=D:\aplikacja_epir
# EDOG_AUDITOR_MODEL_ID=claude-4-sonnet
# EPIR_ANALYST_WORKER_ORIGIN=
# ANALYST_HTTP_BEARER=
