# Cloudflare Workers - zmienne lokalne (kopiuj do .dev.vars)
# Uwaga: .dev.vars jest w .gitignore

# Opcjonalnie: token Admin API do skryptów (np. add-cta-fields-section-hero.mjs)
# Shopify Admin → Settings → Apps → Develop apps → Create app → Configure Admin API → write_metaobject_definitions
# SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxx

SESSION_SECRET=your-secret
BRAND=zareczyny
# Hub + dwie podkolekcje (złote / srebrne) — handle’e muszą istnieć i być opublikowane w kanale Headless
COLLECTION_FILTER=pierscionki-zareczynowe,zareczyny-zlote,zareczyny-srebrne
COLLECTION_HUB_HANDLE=pierscionki-zareczynowe
COLLECTION_GOLD_HANDLE=zareczyny-zlote
COLLECTION_SILVER_HANDLE=zareczyny-srebrne
# Sklep (musi się zgadzać z tokenem Storefront API z tego samego Shopify Admin → Headless channel)
PUBLIC_STORE_DOMAIN=epir-art-silver-jewellery.myshopify.com
PUBLIC_CHECKOUT_DOMAIN=checkout.shopify.com

# PUBLIC_STOREFRONT_API_TOKEN — skopiuj z Shopify Admin dla tego TENANTA (`PUBLIC_STORE_DOMAIN`).
# Nie używaj tokenu pod innego sklepu ani placeholdera „your-token”: SFAPI wtedy zwykle → 403.
# PRIVATE_STOREFRONT_API_TOKEN — delegate access token dla Storefront API (Hydrogen/BFF `/api/*/graphql.json`).
PUBLIC_STOREFRONT_API_TOKEN=your-token
PRIVATE_STOREFRONT_API_TOKEN=your-token
# Opcjonalnie: wersja Storefront API (domyślnie 2025-10 — zgodna z `PUBLIC_STOREFRONT_API_VERSION` w wrangler.toml)
# PUBLIC_STOREFRONT_API_VERSION=2025-10
# Jak w gid://shopify/Storefront/<ID> lub w ustawieniach Headless storefrontu dla tego kanału
PUBLIC_STOREFRONT_ID=1000013955
# Hydrogen i18n (koszyk, ceny, kraj kupującego). Domyślnie PL — ustaw inny jeśli sklep obsługuje inny rynek.
# PUBLIC_STOREFRONT_COUNTRY=PL
# PUBLIC_STOREFRONT_LANGUAGE=PL
SHOP_ID=55145660472
# Shop Pay (Hydrogen) — "true" tylko gdy włączysz Shopify Payments + Shop Pay; inaczej zostaw false lub pomiń
# SHOP_PAY_ENABLED=false
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=your-client-id

# Chat worker – dev: localhost, prod: asystent.epirbizuteria.pl
# Proxy czatu (to samo co na workerze): wrangler secret list w workers/chat
EPIR_CHAT_SHARED_SECRET=twoj-shared-secret
