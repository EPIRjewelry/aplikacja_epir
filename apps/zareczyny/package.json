{
  "name": "zareczyny",
  "private": true,
  "sideEffects": false,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "npm run build:css && remix build",
    "build:css": "npx postcss-cli app/styles/tailwind.css -o app/styles/tailwind-build.css --env production",
    "dev": "npm run build:css && concurrently -g -r npm:dev:wrangler npm:dev:css \"remix watch\"",
    "dev:css": "npx postcss-cli app/styles/tailwind.css -o app/styles/tailwind-build.css -w",
    "dev:wrangler": "cross-env NODE_ENV=development npm run wrangler",
    "preview": "npm run build && shopify hydrogen preview",
    "lint": "eslint --no-error-on-unmatched-pattern --ext .js,.ts,.jsx,.tsx .",
    "typecheck": "tsc --noEmit",
    "wrangler": "wrangler pages dev ./public",
    "deploy": "npm run build && wrangler pages deploy public --project-name=zareczyny-hydrogen-pages --branch=main"
  },
  "prettier": "@shopify/prettier-config",
  "dependencies": {
    "@epir/ui": "*",
    "@epir/utils": "*",
    "@headlessui/react": "^2.2.10",
    "@remix-run/cloudflare": "^2.15.0",
    "@remix-run/cloudflare-pages": "^2.15.0",
    "@remix-run/react": "^2.15.0",
    "@shopify/cli": "3.93.1",
    "@shopify/cli-hydrogen": "^11.1.12",
    "@shopify/hydrogen": "^2026.1.3",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "graphql": "^16.6.0",
    "graphql-tag": "^2.12.6",
    "isbot": "^5.1.37",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tiny-invariant": "^1.2.0"
  },
  "devDependencies": {
    "@epir/config": "*",
    "@cloudflare/workers-types": "^4.20230518.0",
    "@remix-run/dev": "^2.15.0",
    "@shopify/prettier-config": "^1.1.2",
    "@types/eslint": "^9.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.14",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-plugin-hydrogen": "0.12.5",
    "postcss": "^8.4.24",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.3.2",
    "typescript": "^6.0.2",
    "wrangler": "4.81.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
