# Copy to .dev.vars for local wrangler dev (never commit .dev.vars).
# Production: wrangler secret put MARKETING_OPS_BEARER_TOKEN

MARKETING_OPS_BEARER_TOKEN=
# Same value semantics as MARKETING_OPS_PREVIEW_KEY on epir-marketing-ingest.

OPENROUTER_API_KEY=
# Production: wrangler secret put OPENROUTER_API_KEY

OPENROUTER_DEFAULT_MODEL=meta-llama/llama-2-70b-chat
# Opcjonalny domyślny model z listy w src/openrouter-config.ts
