{% liquid
  assign default_title = 'Czat z Gemmą'
  assign default_greeting = 'Witaj! Jestem Gemmą, doradczynią EPIR Art Jewellery. Jak mogę pomóc w wyborze biżuterii?'
  assign default_placeholder = 'Napisz wiadomość, np. „Pokaż pierścionki zaręczynowe z szafirem”'
  assign default_start_closed = true
  assign app_version = 'v1.5.0-attach-preview-2026-04-08'
%}

{% schema %}
{
  "name": "Asystent EPIR embed",
  "target": "body",
  "javascript": "assistant.js",
  "settings": [
    {
      "type": "header",
      "content": "Ustawienia ogólne widgetu"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Tytuł panelu (PersonaUi.chatTitle)",
      "default": "Czat z Gemmą"
    },
    {
      "type": "text",
      "id": "greeting_message",
      "label": "Wiadomość powitalna (pierwszy komunikat w panelu)",
      "default": "Witaj! Jestem Gemmą, doradczynią EPIR Art Jewellery. Jak mogę pomóc w wyborze biżuterii?"
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Tekst w polu wprowadzania",
      "default": "Napisz wiadomość, np. „Pokaż pierścionki zaręczynowe z szafirem”"
    },
    {
      "type": "checkbox",
      "id": "start_closed",
      "label": "Start jako launcher – panel otwiera się po kliknięciu",
      "default": true
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Kolor akcentujący (przycisk)",
      "default": "#8B7D6A"
    },
    {
      "type": "text",
      "id": "storefront_id",
      "label": "Storefront ID (kontekst workera)",
      "default": "epir-liquid"
    },
    {
      "type": "text",
      "id": "channel",
      "label": "Kanał (kontekst workera)",
      "default": "online-store"
    }
  ],
  "default": {
    "settings": {
      "title": "Czat z Gemmą",
      "greeting_message": "Witaj! Jestem Gemmą, doradczynią EPIR Art Jewellery. Jak mogę pomóc w wyborze biżuterii?",
      "input_placeholder": "Napisz wiadomość, np. „Pokaż pierścionki zaręczynowe z szafirem”",
      "start_closed": true,
      "storefront_id": "epir-liquid",
      "channel": "online-store",
      "accent_color": "#8B7D6A"
    }
  }
}
{% endschema %}

<section id="epir-assistant-embed"
  class="epir-assistant epir-assistant-section epir-assistant--bottom-right"
  aria-live="polite"
  data-app-version="{{ app_version }}"
  data-shop-domain="{{ shop.myshopify_domain }}"
  data-logged-in-customer-id="{{ customer.id | default: '' }}"
  data-worker-endpoint="/apps/assistant/chat"
  data-storefront-id="{{ block.settings.storefront_id | default: 'epir-liquid' }}"
  data-channel="{{ block.settings.channel | default: 'online-store' }}"
  data-brand="epir"
  data-start-closed="{{ block.settings.start_closed | default: default_start_closed }}"
  data-stream-render="dots"
>
  <style>
    #epir-assistant-embed .assistant-form button {
      background-color: {{ block.settings.accent_color | default: '#8B7D6A' }};
    }
    #epir-assistant-embed .assistant-status {
      color: {{ block.settings.accent_color | default: '#8B7D6A' }};
    }
    #epir-assistant-embed #assistant-input-embed:focus {
      border-color: {{ block.settings.accent_color | default: '#8B7D6A' }};
    }
    #epir-assistant-embed .epir-assistant-launcher {
      background-color: {{ block.settings.accent_color | default: '#8B7D6A' }};
    }
    #epir-assistant-embed .assistant-loader {
      display: flex;
      justify-content: center;
      align-items: center;
      height: 32px;
      font-size: 2em;
      color: {{ block.settings.accent_color | default: '#8B7D6A' }};
      margin-top: 8px;
    }
    #epir-assistant-embed .assistant-loader .dot {
      animation: epir-blink 1.4s infinite both;
      margin: 0 2px;
    }
    #epir-assistant-embed .assistant-loader .dot:nth-child(2) { animation-delay: 0.2s; }
    #epir-assistant-embed .assistant-loader .dot:nth-child(3) { animation-delay: 0.4s; }
    @keyframes epir-blink {
      0%, 80%, 100% { opacity: 0; }
      40% { opacity: 1; }
    }
  </style>

  <div class="assistant-container">
    <div
      id="assistant-panel-embed"
      class="assistant-panel{% unless block.settings.start_closed == false %} is-closed{% endunless %}"
    >
      <div class="assistant-header" role="heading" aria-level="3">
        <h3>{{ block.settings.title | default: default_title }}</h3>
        <button id="assistant-close-button-embed" class="assistant-close-btn" aria-label="Zamknij panel czatu">
          ✕
        </button>
      </div>

      <div id="assistant-content-embed" class="assistant-content">
      <div id="assistant-messages-embed" class="assistant-messages" role="log" aria-atomic="false" aria-live="polite">
        <div class="msg msg-assistant welcome-message" role="status">
          {{ block.settings.greeting_message | default: default_greeting }}
        </div>
      </div>

      <form id="assistant-form-embed" class="assistant-form" onsubmit="return false;" action="javascript:void(0)">
        <label for="assistant-input-embed" class="sr-only">Wpisz wiadomość do Gemmy</label>
        <input
          id="assistant-input-embed"
          type="text"
          placeholder="{{ block.settings.input_placeholder | default: default_placeholder }}"
          autocomplete="off"
          required
          maxlength="256"
          aria-required="true"
        >
        <button type="button" id="assistant-send-button-embed" aria-label="Wyślij wiadomość">
          Wyślij
        </button>
      </form>

      <div id="assistant-status-embed" class="assistant-status" role="status" aria-live="polite"></div>
      <div id="assistant-loader-embed" class="assistant-loader" style="display:none" aria-live="polite" aria-label="Oczekiwanie na odpowiedź">
        <span class="dot">.</span><span class="dot">.</span><span class="dot">.</span>
      </div>
      </div>
    </div>

    <button
      id="assistant-launcher-embed"
      class="epir-assistant-launcher"
      aria-expanded="false"
      aria-controls="assistant-panel-embed"
      aria-label="{{ block.settings.title | default: default_title }}"
    >
      Czat
    </button>
  </div>
</section>

{{ 'assistant.css' | asset_url | stylesheet_tag }}
<script src="{{ 'assistant.js' | asset_url }}" defer></script>
