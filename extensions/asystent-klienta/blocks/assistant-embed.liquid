{% comment %}
  App Embed – Asystent Klienta AI (target: body).
  Pojawia się w "App embeds", wstrzykiwany do body na wszystkich stronach.
  Używa tych samych assetów co blok sekcji.
{% endcomment %}

{% liquid
  assign default_title = 'Zapytaj Doradcę EPIR-ART'
  assign default_greeting = 'Witaj w EPIR-ART. Jestem Twoim osobistym doradcą AI, gotowym pomóc w wyborze idealnej biżuterii.'
  assign default_placeholder = 'Wpisz wiadomość, np. „Pokaż mi pierścionki zaręczynowe z szafirem”'
  assign default_start_closed = true
  assign app_version = 'v1.1.6-launcher-inside-section-2026-03-29'
%}

{% schema %}
{
  "name": "Asystent EPIR embed",
  "target": "body",
  "stylesheet": "assistant.css",
  "javascript": "assistant.js",
  "settings": [
    {
      "type": "header",
      "content": "Ustawienia Ogólne Widgetu"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Tytuł Widgetu",
      "default": "Zapytaj Doradcę EPIR-ART"
    },
    {
      "type": "text",
      "id": "greeting_message",
      "label": "Wiadomość Powitalna",
      "default": "Witaj w EPIR-ART. Jestem Twoim osobistym doradcą AI, gotowym pomóc w wyborze idealnej biżuterii."
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Tekst w polu wprowadzania",
      "default": "Wpisz wiadomość, np. „Pokaż mi pierścionki zaręczynowe z szafirem”"
    },
    {
      "type": "checkbox",
      "id": "start_closed",
      "label": "Start jako launcher – panel otwiera się po kliknięciu",
      "default": true
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Kolor Akcentujący (Przycisk)",
      "default": "#8B7D6A"
    },
    {
      "type": "text",
      "id": "worker_endpoint",
      "label": "URL workera czatu",
      "info": "Endpoint czatu (zalecane Shopify App Proxy: /apps/assistant/chat)",
      "default": "/apps/assistant/chat"
    }
  ],
  "default": {
    "settings": {
      "title": "Zapytaj Doradcę EPIR-ART",
      "greeting_message": "Witaj w EPIR-ART. Jestem Twoim osobistym doradcą AI, gotowym pomóc w wyborze idealnej biżuterii.",
      "start_closed": true,
      "worker_endpoint": "/apps/assistant/chat"
    }
  }
}
{% endschema %}

<section id="epir-assistant-embed"
  class="epir-assistant epir-assistant-section epir-assistant--bottom-right"
  aria-live="polite"
  data-app-version="{{ app_version }}"
  data-shop-domain="{{ shop.myshopify_domain }}"
  data-logged-in-customer-id="{{ customer.id | default: '' }}"
  data-worker-endpoint="{{ block.settings.worker_endpoint | default: '/apps/assistant/chat' }}"
  data-brand="epir"
  data-start-closed="{{ block.settings.start_closed | default: default_start_closed }}"
  data-stream-render="dots"
>
  <style>
    #epir-assistant-embed .assistant-form button {
        background-color: {{ block.settings.accent_color | default: '#8B7D6A' }};
    }
    #epir-assistant-embed .assistant-status {
        color: {{ block.settings.accent_color | default: '#8B7D6A' }};
    }
    #epir-assistant-embed #assistant-input-embed:focus {
        border-color: {{ block.settings.accent_color | default: '#8B7D6A' }};
    }
  </style>

  <div class="assistant-container">
    <div class="assistant-header" role="heading" aria-level="3">
      <h3>{{ block.settings.title | default: default_title }}</h3>
      <button id="assistant-close-button-embed" class="assistant-close-btn" aria-label="Zamknij panel czatu">
        ✕
      </button>
    </div>

  <div id="assistant-content-embed" class="assistant-content is-closed">
        <div id="assistant-messages-embed" class="assistant-messages" role="log" aria-atomic="false" aria-live="polite">
          <div class="msg msg-assistant welcome-message" role="status">
            {{ block.settings.greeting_message | default: default_greeting }}
          </div>
        </div>

        <form id="assistant-form-embed" class="assistant-form" onsubmit="return false;" action="javascript:void(0)">
          <label for="assistant-input-embed" class="sr-only">Wpisz wiadomość do doradcy</label>
          <input
            id="assistant-input-embed"
            type="text"
            placeholder="{{ block.settings.input_placeholder | default: default_placeholder }}"
            autocomplete="off"
            required
            maxlength="256"
            aria-required="true"
          />
          <button type="button" id="assistant-send-button-embed" aria-label="Wyślij wiadomość">
            Wyślij
          </button>
        </form>
        <div id="assistant-status-embed" class="assistant-status" role="status" aria-live="polite"></div>
        <div id="assistant-loader-embed" class="assistant-loader" style="display:none" aria-live="polite" aria-label="Oczekiwanie na odpowiedź">
          <span class="dot">.</span><span class="dot">.</span><span class="dot">.</span>
        </div>
    </div>
  </div>

  <style>
    #epir-assistant-embed .epir-assistant-launcher {
      background-color: {{ block.settings.accent_color | default: '#8B7D6A' }};
    }
    .assistant-loader {
      display: flex;
      justify-content: center;
      align-items: center;
      height: 32px;
      font-size: 2em;
      color: {{ block.settings.accent_color | default: '#8B7D6A' }};
      margin-top: 8px;
    }
    .assistant-loader .dot {
      animation: blink 1.4s infinite both;
      margin: 0 2px;
    }
    .assistant-loader .dot:nth-child(2) { animation-delay: 0.2s; }
    .assistant-loader .dot:nth-child(3) { animation-delay: 0.4s; }
    @keyframes blink {
      0%, 80%, 100% { opacity: 0; }
      40% { opacity: 1; }
    }
  </style>

  <!-- Launcher musi być wewnątrz #epir-assistant-embed — runtime szuka go przez section.querySelector -->
  <button id="assistant-launcher-embed" class="epir-assistant-launcher" aria-expanded="false" aria-controls="assistant-content-embed" aria-label="{{ block.settings.title | default: default_title }}">
    🗣
  </button>
</section>
