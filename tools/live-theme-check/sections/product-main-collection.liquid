{%- comment -%}
  ----------------------------------------------------------------------------------
  Section: Product Main Collection (Hybrid Ready)
  Version: 1.2.3 (Fixed Rich Text metafield parsing)
  Integration: Uses Native Collection + Custom Metafields
  Author: Gemini (Shopify Expert) for EPIR
  
  SETUP REQUIRED:
  1. Collection Metafields (Settings > Custom Data > Collections):
     - custom.mood_image (File/Image)
     - custom.brand_story (Rich Text)
  2. Assign collections to products.
  ----------------------------------------------------------------------------------
{%- endcomment -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Scoped Variables */
  #shopify-section-{{ section.id }} {
    --section-bg: {{ section.settings.bg_color }};
    --section-text: {{ section.settings.text_color }};
    --text-alignment: {{ section.settings.text_alignment }};
  }
{%- endstyle -%}

{%- comment -%} LOGIC: Target Collection Selection {%- endcomment -%}
{%- assign target_collection = blank -%}

{%- comment -%} 1. Check direct override via Product Metafield (optional) {%- endcomment -%}
{%- if product.metafields.custom.main_collection.value != blank -%}
  {%- assign target_collection = product.metafields.custom.main_collection.value -%}
{%- elsif product.collections.first != blank -%}
  {%- comment -%} 2. Fallback to first native collection {%- endcomment -%}
  {%- assign target_collection = product.collections.first -%}
{%- endif -%}

{%- if target_collection != blank -%}

  {%- comment -%} DATA SOURCE: Priority to Collection Metafields (Mood Image) {%- endcomment -%}
  {%- assign mood_image = target_collection.metafields.custom.mood_image.value | default: target_collection.image | default: target_collection.products.first.featured_image -%}
  {%- assign brand_story_metafield = target_collection.metafields.custom.brand_story -%}
  
  {%- comment -%} Parse Rich Text metafield or fallback to description {%- endcomment -%}
  {%- if brand_story_metafield != blank -%}
    {%- assign story_text = brand_story_metafield.value -%}
  {%- else -%}
    {%- assign story_text = target_collection.description -%}
  {%- endif -%}

  <div class="product-main-collection" style="background-color: var(--section-bg); color: var(--section-text);">
    <div class="page-width section-{{ section.id }}-padding">
      <div class="product-main-collection__container product-main-collection__layout--{{ section.settings.layout }}">
        
        {%- if section.settings.show_image -%}
          <div class="product-main-collection__media-wrapper">
            <figure class="product-main-collection__media product-main-collection__media--{{ section.settings.image_ratio }}">
              {%- if mood_image != blank -%}
                <img
                  srcset="{{ mood_image | image_url: width: 375 }} 375w,
                          {{ mood_image | image_url: width: 550 }} 550w,
                          {{ mood_image | image_url: width: 750 }} 750w,
                          {{ mood_image | image_url: width: 1100 }} 1100w,
                          {{ mood_image | image_url: width: 1500 }} 1500w"
                  src="{{ mood_image | image_url: width: 1200 }}"
                  sizes="(min-width: 750px) 50vw, 100vw"
                  alt="{{ target_collection.title | escape }}"
                  loading="lazy"
                  class="product-main-collection__image"
                  width="{{ mood_image.width }}"
                  height="{{ mood_image.height }}"
                >
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg product-main-collection__image' }}
              {%- endif -%}
            </figure>
          </div>
        {%- endif -%}

        <div class="product-main-collection__content">
          <h2 class="product-main-collection__heading h2">
            {{ section.settings.heading | escape }} <span class="product-main-collection__title">{{ target_collection.title }}</span>
          </h2>

          {%- if section.settings.show_count -%}
             <p class="product-main-collection__count caption-with-letter-spacing">
              {{ target_collection.products_count }} 
              {%- if target_collection.products_count == 1 -%} produkt
              {%- elsif target_collection.products_count >= 2 and target_collection.products_count <= 4 -%} produkty
              {%- else -%} produktów
              {%- endif -%}
            </p>
          {%- endif -%}

          {%- if story_text != blank and section.settings.desc_length > 0 -%}
            <div class="product-main-collection__description rte">
              {%- if brand_story_metafield != blank -%}
                {{ brand_story_metafield | metafield_text | strip_html | truncate: section.settings.desc_length }}
              {%- else -%}
                {{ story_text | strip_html | truncate: section.settings.desc_length }}
              {%- endif -%}
            </div>
          {%- endif -%}

          <div class="product-main-collection__cta-wrapper">
            <a href="{{ target_collection.url }}" class="product-main-collection__button button--{{ section.settings.button_style }}">
              {{ section.settings.button_text | default: "Zobacz całą kolekcję" }}
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>

  {%- style -%}
    /* COMPONENT STYLES (Scoped CSS) */
    .product-main-collection__container {
      display: flex;
      gap: 3rem;
      align-items: center;
      flex-direction: column;
    }

    .product-main-collection__content {
      flex: 1;
      text-align: var(--text-alignment);
      width: 100%;
    }

    .product-main-collection__media-wrapper {
      flex: 1;
      width: 100%;
    }

    .product-main-collection__media {
      margin: 0;
      position: relative;
      overflow: hidden;
      border-radius: var(--media-border-radius, 0px); 
      display: block;
      box-shadow: var(--media-shadow-horizontal-offset, 0) var(--media-shadow-vertical-offset, 0) var(--media-shadow-blur-radius, 0) rgba(var(--color-shadow), var(--media-shadow-opacity, 0));
    }

    .product-main-collection__media img, 
    .product-main-collection__media svg {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform var(--duration-long, 0.5s) ease;
    }

    /* Hover Effect */
    .product-main-collection__media:hover img {
      transform: scale(1.05);
    }

    /* Aspect Ratios */
    .product-main-collection__media--square { aspect-ratio: 1 / 1; }
    .product-main-collection__media--portrait { aspect-ratio: 2 / 3; }
    .product-main-collection__media--landscape { aspect-ratio: 16 / 9; }

    /* Typography Colors */
    .product-main-collection__heading,
    .product-main-collection__description,
    .product-main-collection__count {
      color: var(--section-text);
    }

    .product-main-collection__heading {
      margin-bottom: 1rem;
    }
    
    .product-main-collection__description {
      opacity: 0.85;
      margin-bottom: 2.5rem;
      line-height: 1.6;
    }

    /* BUTTON STYLES - FIXED */
    .product-main-collection__button {
      display: inline-block;
      padding: 1.2rem 3rem;
      text-decoration: none;
      font-weight: 600;
      border-radius: 4px;
      transition: all 0.3s ease;
      cursor: pointer;
      text-align: center;
      border: 2px solid transparent;
    }

    /* Primary Button (Default) */
    .product-main-collection__button.button--primary {
      background-color: #2c5f2d;
      color: #ffffff;
      border-color: #2c5f2d;
    }

    .product-main-collection__button.button--primary:hover {
      background-color: #1e4620;
      border-color: #1e4620;
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(44, 95, 45, 0.3);
    }

    /* Secondary Button */
    .product-main-collection__button.button--secondary {
      background-color: #ffffff;
      color: #2c5f2d;
      border-color: #2c5f2d;
    }

    .product-main-collection__button.button--secondary:hover {
      background-color: #f5f5f0;
      border-color: #1e4620;
      color: #1e4620;
    }

    /* Outline Button */
    .product-main-collection__button.button--outline {
      background-color: transparent;
      color: #2c5f2d;
      border-color: #2c5f2d;
    }

    .product-main-collection__button.button--outline:hover {
      background-color: #2c5f2d;
      color: #ffffff;
      border-color: #2c5f2d;
    }

    /* Desktop Layouts */
    @media screen and (min-width: 750px) {
      .product-main-collection__container {
        flex-direction: row;
      }

      .product-main-collection__layout--image_right {
        flex-direction: row-reverse;
      }

      .product-main-collection__layout--image_top {
        flex-direction: column;
        text-align: center;
      }
      
      .product-main-collection__layout--image_top .product-main-collection__media-wrapper {
        max-width: 70rem;
        margin: 0 auto;
      }
    }
  {%- endstyle -%}
{%- endif -%}

{% schema %}
{
  "name": "Main Collection Product",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Prefix",
      "default": "Z kolekcji",
      "info": "Will be followed by the collection title."
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "Show product count",
      "default": false
    },
    {
      "type": "range",
      "id": "desc_length",
      "min": 0,
      "max": 500,
      "step": 10,
      "unit": "ch",
      "label": "Description Max Characters",
      "default": 150
    },
    {
      "type": "header",
      "content": "Button Settings"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Label",
      "default": "Zobacz całą kolekcję"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button Style",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "outline", "label": "Outline" }
      ],
      "default": "primary"
    },
    {
      "type": "header",
      "content": "Image Settings"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Show Collection Image",
      "default": true
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image Aspect Ratio",
      "options": [
        { "value": "square", "label": "Square (1:1)" },
        { "value": "portrait", "label": "Portrait (2:3)" },
        { "value": "landscape", "label": "Landscape (16:9)" }
      ],
      "default": "square"
    },
    {
      "type": "header",
      "content": "Layout & Style"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Desktop Layout",
      "options": [
        { "value": "image_left", "label": "Image Left" },
        { "value": "image_right", "label": "Image Right" },
        { "value": "image_top", "label": "Image Top (Stacked)" }
      ],
      "default": "image_left"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Main Collection Product"
    }
  ]
}
{% endschema %}
