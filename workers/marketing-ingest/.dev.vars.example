# Kopiuj do .dev.vars (nie commituj). Nazwy zgodne z Env w src/index.ts.
# MARKETING_PIPELINE_INGEST_URL=https://....ingest.cloudflare.com
# MARKETING_PIPELINE_INGEST_TOKEN=
# GA4_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_REFRESH_TOKEN=
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_CUSTOMER_ID=
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=   # opcjonalnie MCC (CID menedżera, bez myślników)
# MARKETING_OPS_PREVIEW_KEY=      # opcjonalnie: Bearer do GET /ops/marketing-preview
# GA4_PROPERTY_ID ustaw w wrangler.toml [vars] lub tutaj dla lokalnego dev.
