# Skopiuj do .ads-smoke.env (ten plik jest w .gitignore). Wypełnij wartościami z Cloudflare / Google.
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_REFRESH_TOKEN=
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_CUSTOMER_ID=
# Opcjonalnie — CID menedżera (MCC), bez myślników, gdy zapytanie idzie do konta klienckiego:
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=
